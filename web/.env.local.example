# Classical Chinese Workbench web runtime
# Copy to web/.env.local for local development or configure equivalent deploy secrets.
# Boundary: Supabase stores auditable metadata; env/secret manager stores real secrets and machine-local paths.

# Public browser-safe Supabase settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy Supabase projects can use ANON_KEY instead of PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase/admin secret. Never expose through NEXT_PUBLIC_* or client UI.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI SDK provider routing (server-only)
# Provider/model IDs are persisted in Supabase provider_configs/provider_capabilities.
# These env keys are runtime secrets referenced by Supabase secret_ref values such as env:OPENAI_API_KEY.
# Missing keys must fail clearly; no placeholder AI fallback is allowed.
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Explicit optional provider integrations (server-only; not implicit fallbacks)
GROK_API_URL=https://api.x.ai/v1
GROK_API_KEY=
GROK_MODEL=
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Local model runtime (server-only, environment-scoped)
# Model binaries/absolute paths are never committed and are not shared Supabase business config.
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL_PROVIDER=
LOCAL_MODEL_PATH=
LOCAL_MODEL_BASE_URL=
LOCAL_MODEL_CONTEXT_WINDOW=
LOCAL_EMBEDDING_MODEL_PATH=

# MCP runtime bridge (server-only, environment-scoped)
# Supabase stores MCP metadata/capabilities/role scope/secret_ref/last-four only.
# Local command paths, bridge tokens, and server env stay here or in a secret manager.
MCP_BRIDGE_ENABLED=false
MCP_BRIDGE_TOKEN=
MCP_BRIDGE_COMMAND=
MCP_BRIDGE_ENV_JSON=
MCP_BRIDGE_BASE_URL=

# Development-only network/runtime settings
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=
